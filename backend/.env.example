### Clinical Trial Finder — backend environment example
# Copy this file to backend/.env and fill in secrets before running locally.

# API keys
MAPQUEST_API_KEY=
GEOAPIFY_API_KEY=
APOLLO_API_KEY=
GROQ_API_KEY=
GROQ_API_URL=

# Salesforce — Web-to-Lead (legacy, kept for fallback reference)
SF_OID=
SF_RET_URL=
SF_WEB_TO_LEAD_URL=https://webto.salesforce.com/servlet/servlet.WebToLead?encoding=UTF-8
SF_DEBUG_EMAIL=
SF_NPI_FIELD=
SF_SPECIALIZATION_FIELD=
SF_GENDER_FIELD=
SF_GENDER_IDENTITY_FIELD=

# Salesforce — REST API (active integration)
# These 5 values replace Web-to-Lead and fix GenderIdentity field mapping.
# SF_PASSWORD = Salesforce password + security token joined (no space)
# Example: password "Winter2024!" + token "xKp9ABC" = "Winter2024!xKp9ABC"
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_INSTANCE_URL=
SF_API_VERSION=59.0
# SF_LOGIN_URL: only needed if your org uses a custom domain
# Default is https://login.salesforce.com
# Change to https://yourorg.my.salesforce.com if you get invalid_grant errors
SF_LOGIN_URL=

# CORS / Server
FRONTEND_URL=http://localhost:3000
PORT=8000
DEBUG_SECRET=

# ZIP loading behavior
# Set to '1' to load ZIP DB synchronously (useful in some hosting environments)
ZIP_LOAD_SYNC=0

# Render / hosting flags
RENDER=0
