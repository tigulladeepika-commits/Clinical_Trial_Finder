### Clinical Trial Finder — backend environment example
# Copy this file to backend/.env and fill in secrets before running locally.

# API keys
MAPQUEST_API_KEY=
GEOAPIFY_API_KEY=
APOLLO_API_KEY=
GROQ_API_KEY=
GROQ_API_URL=

# Salesforce (optional)
SF_OID=
SF_RET_URL=
SF_DEBUG_EMAIL=

# CORS / Server
FRONTEND_URL=http://localhost:3000
PORT=8000
DEBUG_SECRET=

# ZIP loading behavior
# Set to '1' to load ZIP DB synchronously (useful in some hosting environments)
ZIP_LOAD_SYNC=0

# Render / hosting flags
RENDER=0
