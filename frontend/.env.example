# Preferred for Vercel or local proxying through Next.js rewrites.
API_URL=http://localhost:8000

# Optional direct browser-to-backend URL. Leave empty when using API_URL rewrites.
NEXT_PUBLIC_API_URL=

# Public browser keys used by the map UI.
NEXT_PUBLIC_MAPQUEST_KEY=your_mapquest_browser_key
NEXT_PUBLIC_GEOAPIFY_KEY=your_geoapify_key
